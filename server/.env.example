# Meta Ads (Marketing API) — copie para server/.env e preencha
# NÃO comite o .env. Ele já está no .gitignore.

# Token de acesso. De preferência um token de System User (longa duração)
# com a permissão ads_read (e ads_management se quiser escrever/pausar).
META_ACCESS_TOKEN=

# Opcional: se você já sabe a conta, fixe aqui (aceita act_123 ou só 123).
# Se deixar vazio, o validador lista todas as contas que o token enxerga.
META_AD_ACCOUNT_ID=

# Versão da Graph API. v23.0 é estável em 2025/2026.
META_API_VERSION=v23.0

# --- Criação de campanhas (escrita). Use server/meta/discover-ids.mjs p/ achar. ---
# Página do Facebook usada no criativo (object_story_spec.page_id). Obrigatório p/ criar anúncio.
META_PAGE_ID=
# Pixel para otimizar por evento de lead (promoted_object).
# Se vazio, a campanha de teste otimiza por LINK_CLICKS (não por lead).
META_PIXEL_ID=

# --- Chat com IA ---
# O chat tem dois motores. A escolha é por CHAT_PROVIDER:
#   auto (padrão) -> usa a API se houver ANTHROPIC_API_KEY; senão tenta o Claude
#                    local (assinatura); senão cai no modo por regras.
#   api           -> só Claude API (precisa de ANTHROPIC_API_KEY).
#   cli           -> só Claude Code local (dev/testes, usa sua assinatura).
CHAT_PROVIDER=auto

# Motor "api": chave da Anthropic. Em PRODUÇÃO, basta exportar esta variável no
# ambiente do servidor — não é preciso editar este .env (a env real do processo
# tem precedência sobre o .env). Largue a chave aqui e funciona, sem mexer no código.
ANTHROPIC_API_KEY=
# Modelo da API. Default: claude-opus-4-8.
ANTHROPIC_MODEL=

# Motor "cli": usa o binário do Claude Code local para testar SEM chave de API.
# Por padrão detecta ~/.local/bin/claude ou ~/.claude/local/claude. Só funciona
# em dev local (depende da sua assinatura logada). Defina o caminho se necessário.
CLAUDE_CLI_PATH=
# Modelo usado pelo CLI local. Default: claude-opus-4-8
# (use claude-haiku-4-5-20251001 para testes mais baratos).
CHAT_CLI_MODEL=
