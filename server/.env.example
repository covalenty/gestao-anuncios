# Meta Ads (Marketing API) — copie para server/.env e preencha
# NÃO comite o .env. Ele já está no .gitignore.

# Token de acesso. De preferência um token de System User (longa duração)
# com a permissão ads_read (e ads_management se quiser escrever/pausar).
META_ACCESS_TOKEN=

# Opcional: se você já sabe a conta, fixe aqui (aceita act_123 ou só 123).
# Se deixar vazio, o validador lista todas as contas que o token enxerga.
META_AD_ACCOUNT_ID=

# Versão da Graph API. v23.0 é estável em 2025/2026.
META_API_VERSION=v23.0
